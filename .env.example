# Vercel Environment Variables Configuration
# Copy this to your Vercel dashboard: Settings > Environment Variables

# API Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration (add your frontend domain)
CORS_ORIGIN=https://your-frontend-domain.com,http://localhost:3000

# Database Configuration (NOT USED IN SERVERLESS MODE - MOCKED)
# These are kept for reference only - API uses mock data
# DB_HOST=your-database-host
# DB_USER=your-database-user
# DB_PASSWORD=your-database-password
# DB_NAME=blood_bank
# DB_PORT=3306

# JWT Configuration 
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES=7d

# Notifications (Disabled in serverless)
NOTIFICATIONS_MOCK=true

# SMTP email settings (Not used in serverless)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=BloodLink Hub <no-reply@bloodlink.local>

# SMS settings - Twilio (Not used in serverless)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_FROM_NUMBER=your-number
